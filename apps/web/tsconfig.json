{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "paths": {
      "~/*": ["./src/*"]
    },
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
